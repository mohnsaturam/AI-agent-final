# ── Database ──
DATABASE_URL=postgresql://{hostname}@{localhost}:5432/postgres

# ── JWT ──
JWT_SECRET=change-me-in-production

# ── AI Provider (Groq — OpenAI-compatible) ──
# Get your free API keys at https://console.groq.com/keys
# Phase 1: Unification + Intent understanding + Site relevance scoring
AI_API_KEY_PHASE1=your-groq-api-key-phase1
# Phase 2: DOM scoring
AI_API_KEY_PHASE2=your-groq-api-key-phase2
# Phase 3: Query expansion
AI_API_KEY_PHASE3=your-groq-api-key-phase3
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_MODEL_TIER2=llama-3.3-70b-versatile

# ── To switch to OpenAI later, just change these: ──
# AI_API_KEY=sk-your_openai_key
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI_MODEL_TIER2=gpt-4o

# ── CORS ──
CORS_ORIGINS=["http://localhost:5173"]
